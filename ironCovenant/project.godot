config_version=5

[application]

config/name="Iron Covenant"
config/version="0.0.0"
run/main_scene="uid://dy53kd20h4anj"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")

[autoload]

SceneManager="*uid://diicdj4h77m67"
VariableManager="*uid://do2as7mextx10"
AutoSceneManagerInstance="*uid://c4shvxaem8lyo"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="Iron Covenant"

